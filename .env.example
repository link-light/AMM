# AI Money Machine - Environment Configuration

# ============================================
# Application
# ============================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================
# Database (PostgreSQL 15 with pgvector)
# ============================================
DB_USER=amm
DB_PASSWORD=ammpass
DB_NAME=amm
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://amm:ammpass@localhost:5432/amm

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# AI API Keys
# ============================================
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# ============================================
# Budget Configuration ($)
# ============================================
# Hard limits (cannot be exceeded)
DAILY_HARD_LIMIT=20.0
MONTHLY_HARD_LIMIT=400.0
PER_TASK_LIMIT=5.0

# Soft limits (trigger warnings)
DAILY_SOFT_LIMIT=15.0
MONTHLY_SOFT_LIMIT=300.0

# Minimum profit ratio (expected_profit >= ai_cost * ratio)
MIN_PROFIT_RATIO=3.0

# ============================================
# Rate Limiting
# ============================================
# Opus tier
OPUS_RPM=30
OPUS_TPM=100000
OPUS_DAILY_COST=50.0

# Sonnet tier
SONNET_RPM=60
SONNET_TPM=200000
SONNET_DAILY_COST=30.0

# Haiku tier
HAIKU_RPM=120
HAIKU_TPM=500000
HAIKU_DAILY_COST=10.0

# ============================================
# Circuit Breaker
# ============================================
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_TIMEOUT=60
CIRCUIT_HALF_OPEN_MAX_CALLS=3

# ============================================
# Cache Configuration
# ============================================
CACHE_TTL=3600
CACHE_MAX_SIZE=10000

# ============================================
# Authentication
# ============================================
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Admin credentials (for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ============================================
# Mock Mode (for development)
# ============================================
MOCK_AI=true
MOCK_SCOUTS=true

# ============================================
# Scout Configuration
# ============================================
FREELANCE_SCOUT_INTERVAL=1800

# ============================================
# Feature Flags
# ============================================
ENABLE_AUDIT_LOG=true
ENABLE_COST_TRACKING=true
ENABLE_CIRCUIT_BREAKER=true
